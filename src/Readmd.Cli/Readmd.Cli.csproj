<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <AssemblyName>readmd</AssemblyName>
    <RootNamespace>Readmd.Cli</RootNamespace>

    <!-- .NET tool packaging: enables `dnx readmd <file>` / `dotnet tool install -g readmd` -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>readmd</ToolCommandName>
    <PackageId>readmd</PackageId>
    <Version>0.5.1</Version>
    <InformationalVersion>0.5.1</InformationalVersion>
    <!-- Keep the version line clean ("readmd 0.4.0"): don't let SourceLink append a +commit suffix
         to the informational version, which Program.cs reads for the branded version output. -->
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    <Authors>MoaidHathot</Authors>
    <Title>readmd — terminal Markdown viewer</Title>
    <Description>A terminal-first, feature-rich Markdown viewer with live reload, search, [[_TOC_]], mermaid and D2 diagrams, and an optional browser mode.</Description>
    <PackageTags>markdown;viewer;tui;terminal;mermaid;d2;cli</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageProjectUrl>https://github.com/MoaidHathot/readmd</PackageProjectUrl>
    <RepositoryUrl>https://github.com/MoaidHathot/readmd</RepositoryUrl>
    <RepositoryType>git</RepositoryType>

    <!-- Keep the packed tool small: no debug symbols and no PDBs from our own assemblies. The
         transitive native dependencies (SkiaSharp) otherwise ship ~300 MB of .pdb files, which the
         TrimToolPublishOutput target below also strips. -->
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <IncludeSymbols>false</IncludeSymbols>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <NoWarn>$(NoWarn);NU5111</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Readmd.Core\Readmd.Core.csproj" />
    <ProjectReference Include="..\Readmd.Diagrams\Readmd.Diagrams.csproj" />
    <ProjectReference Include="..\Readmd.Web\Readmd.Web.csproj" />
    <ProjectReference Include="..\Readmd.Terminal\Readmd.Terminal.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.CommandLine" Version="3.0.0-preview.5.26302.115" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" Condition="Exists('..\..\README.md')" />
  </ItemGroup>

  <!--
    Trim the packed tool. A .NET tool bundles the full publish output for every runtime, which for
    our dependencies means ~300 MB of SkiaSharp .pdb symbols, ~566 MB of Playwright's per-OS Node.js
    binaries, and SkiaSharp native libraries for ~21 runtimes (incl. Android/iOS-Catalyst/RISC-V/
    LoongArch and exotic musl arches that a desktop CLI never targets). We strip PDBs, Playwright's
    per-OS Node binaries (keeping its small cross-platform JS driver so PDF export still works via a
    system Node.js), and keep only the mainstream desktop runtimes below. This takes the package from
    ~210 MB down to a reasonable size. Chromium (for PDF export) is provisioned on demand at runtime.
  -->
  <PropertyGroup>
    <!-- Pipe-delimited so we can do a simple substring membership test per file. -->
    <_KeepRuntimes>|win-x64|win-x86|win-arm64|linux-x64|linux-arm64|linux-musl-x64|linux-musl-arm64|osx|osx-x64|osx-arm64|</_KeepRuntimes>
  </PropertyGroup>

  <Target Name="TrimToolPublishOutput" BeforeTargets="ComputeFilesToPublish">
    <ItemGroup>
      <!-- Normalize the relative path once for matching. -->
      <ResolvedFileToPublish>
        <_RelPath>$([System.String]::Copy('%(ResolvedFileToPublish.RelativePath)').Replace('\','/'))</_RelPath>
      </ResolvedFileToPublish>

      <!-- Debug symbols: never needed at runtime. -->
      <ResolvedFileToPublish Remove="@(ResolvedFileToPublish)" Condition="'%(Extension)' == '.pdb'" />

      <!-- Playwright ships an ~88 MB Node.js binary per OS (~566 MB total) plus a small (~12 MB)
           cross-platform JS driver. PDF export needs only the JS driver: it drives Playwright with a
           Node.js found on the user's machine (PLAYWRIGHT_NODEJS_PATH) and downloads Chromium on
           demand. So strip the per-OS node binaries but KEEP .playwright/package/ (the JS driver)
           and playwright.ps1. -->
      <ResolvedFileToPublish Remove="@(ResolvedFileToPublish)" Condition="$([System.String]::Copy('%(_RelPath)').Contains('.playwright/node/'))" />

      <!-- Native libs for runtimes we don't ship: remove any runtimes/<rid>/ file whose <rid> is
           not in _KeepRuntimes. The condition fires only for runtimes/ paths. -->
      <ResolvedFileToPublish Remove="@(ResolvedFileToPublish)"
        Condition="$([System.String]::Copy('%(_RelPath)').StartsWith('runtimes/')) and
                   !$(_KeepRuntimes.Contains('|$([System.String]::Copy('%(_RelPath)').Split('/')[1])|'))" />
    </ItemGroup>
  </Target>

</Project>
